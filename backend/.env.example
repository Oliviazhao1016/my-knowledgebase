# 火山引擎 API 配置
# 请在此处填入您的火山引擎 API Key 和推理接入点 (Endpoint ID)
VOLCENGINE_API_KEY="your_volcengine_api_key_here"
VOLCENGINE_BASE_URL="https://ark.cn-beijing.volces.com/api/v3"

# 聊天模型接入点 ID (例如 ep-xxxxxx)
CHAT_MODEL_ENDPOINT="your_chat_model_endpoint_here"
# 向量模型接入点 ID (例如 ep-xxxxxx)
EMBEDDING_MODEL_ENDPOINT="your_embedding_model_endpoint_here"
